.order-page {
  padding-top: 0;
}

.status-tabs {
  position: sticky;
  top: 0;
  z-index: 2;
  margin: 0 -24rpx 22rpx;
  padding: 18rpx 24rpx;
  background: #fff7f0;
  white-space: nowrap;
}

.status-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 128rpx;
  height: 62rpx;
  margin-right: 14rpx;
  border-radius: 999px;
  color: #666666;
  background: #ffffff;
  font-size: 25rpx;
}

.status-tab.active {
  color: #ffffff;
  background: #ff6b01;
  font-weight: 700;
}

.order-card {
  margin-bottom: 20rpx;
  padding: 22rpx;
}

.order-head {
  display: flex;
  justify-content: space-between;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f2f2f2;
  color: #999999;
  font-size: 24rpx;
}

.status {
  color: #ff6b01;
  font-weight: 700;
}

.status.finished {
  color: #19a974;
}

.status.canceled {
  color: #999999;
}

.goods-line {
  display: flex;
  align-items: center;
  min-height: 138rpx;
  padding: 18rpx 0;
}

.goods-line image {
  width: 96rpx;
  height: 96rpx;
  border-radius: 12rpx;
}

.goods-info {
  flex: 1;
  min-width: 0;
  padding: 0 18rpx;
}

.goods-name {
  display: -webkit-box;
  overflow: hidden;
  color: #222222;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.35;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.order-address {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding: 14rpx 16rpx;
  border-radius: 12px;
  color: #777777;
  background: #fafafa;
  font-size: 24rpx;
}

.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 14rpx;
  flex-wrap: wrap;
}

.order-actions .ghost-btn,
.primary-small {
  min-width: 150rpx;
  min-height: 62rpx;
  padding: 0 18rpx;
  font-size: 24rpx;
}

.primary-small {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12px;
  color: #ffffff;
  background: #ff6b01;
}

.eval-box {
  margin: 16rpx 0;
  padding: 18rpx;
  border-radius: 12px;
  background: #fff7f0;
}

.stars {
  margin-bottom: 14rpx;
}

.stars text {
  margin-right: 12rpx;
  color: #cccccc;
  font-size: 42rpx;
}

.stars text.active {
  color: #ffb300;
}

.eval-box textarea {
  width: 100%;
  min-height: 130rpx;
  padding: 16rpx;
  border-radius: 12px;
  background: #ffffff;
  font-size: 26rpx;
}

.eval-images {
  display: flex;
  gap: 12rpx;
  margin: 14rpx 0;
  flex-wrap: wrap;
}

.eval-images image {
  width: 110rpx;
  height: 110rpx;
  border-radius: 10rpx;
}

.upload-btn {
  width: 150rpx;
  min-height: 110rpx;
  font-size: 24rpx;
}

.eval-result {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 14rpx;
  padding: 14rpx;
  border-radius: 12px;
  color: #666666;
  background: #fafafa;
  font-size: 24rpx;
}
