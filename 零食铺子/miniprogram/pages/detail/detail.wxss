.detail-page {
  min-height: 100vh;
  padding-bottom: calc(130rpx + env(safe-area-inset-bottom));
  background: #fff7f0;
}

.detail-swiper {
  width: 100%;
  height: 620rpx;
  background: #ffffff;
}

.detail-swiper image {
  width: 100%;
  height: 100%;
}

.detail-main,
.detail-section {
  margin: 22rpx 24rpx 0;
  padding: 26rpx;
}

.name-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.detail-name {
  flex: 1;
  color: #222222;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.35;
}

.favorite {
  flex: none;
  min-width: 112rpx;
  height: 56rpx;
  border: 1rpx solid #ffbd8c;
  border-radius: 999px;
  color: #ff6b01;
  background: #fff7f0;
  font-size: 24rpx;
}

.favorite.active {
  color: #ffffff;
  background: #ff6b01;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-top: 24rpx;
}

.price-row .price {
  font-size: 44rpx;
}

.origin {
  color: #aaaaaa;
  font-size: 24rpx;
  text-decoration: line-through;
}

.stat-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 18rpx;
  color: #777777;
  font-size: 24rpx;
}

.section-title {
  margin-bottom: 14rpx;
  font-size: 31rpx;
  font-weight: 800;
}

.desc {
  color: #555555;
  font-size: 27rpx;
  line-height: 1.75;
}

.param-row {
  display: flex;
  justify-content: space-between;
  min-height: 74rpx;
  border-bottom: 1rpx solid #f2f2f2;
  color: #555555;
  font-size: 27rpx;
  line-height: 74rpx;
}

.param-row:last-child {
  border-bottom: none;
}

.param-row text:first-child {
  color: #999999;
}

.buy-bar {
  display: grid;
  grid-template-columns: 120rpx 1fr 1fr;
  gap: 16rpx;
  align-items: center;
}

.share-btn {
  height: 80rpx;
  border: 1rpx solid #eeeeee;
  border-radius: 12px;
  color: #666666;
  background: #ffffff;
  font-size: 25rpx;
}
