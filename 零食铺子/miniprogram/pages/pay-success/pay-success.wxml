<view class="page success-page">
  <view class="success-card card">
    <view class="success-icon">✓</view>
    <text class="success-title">支付成功</text>
    <text class="muted">订单已完成模拟支付，状态已由后端更新为已支付</text>
    <text class="success-amount">¥{{order.totalAmountText}}</text>

    <view class="success-info">
      <view>
        <text>订单编号</text>
        <text>{{order.orderNo}}</text>
      </view>
      <view>
        <text>支付状态</text>
        <text>已支付</text>
      </view>
      <view>
        <text>支付时间</text>
        <text>{{order.paidAt}}</text>
      </view>
    </view>

    <view wx:if="{{order.items && order.items.length}}" class="success-items">
      <view wx:for="{{order.items}}" wx:key="productId" class="success-item">
        <text>{{item.name}}</text>
        <text>x{{item.quantity}}</text>
      </view>
    </view>

    <button class="primary-btn" bindtap="goOrder">查看订单</button>
    <button class="ghost-btn" bindtap="goHome">返回首页</button>
  </view>
</view>
