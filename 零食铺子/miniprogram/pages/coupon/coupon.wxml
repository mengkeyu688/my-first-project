<view class="page coupon-page">
  <view wx:for="{{coupons}}" wx:key="id" class="coupon-card card {{item.status}}">
    <view class="coupon-amount">
      <text>¥</text>
      <text>{{item.amount}}</text>
    </view>
    <view class="coupon-info">
      <text class="coupon-name">{{item.name}}</text>
      <text class="muted">{{item.desc}}</text>
      <text class="muted">有效期至 {{item.expireAt}}</text>
    </view>
    <view class="coupon-status">{{item.status === 'unused' ? '可用' : '已用'}}</view>
  </view>

  <view class="tip-card card">
    <view class="section-title">下单自动计算</view>
    <text>提交订单时系统会在新人券、满减券、配送券中自动选择优惠金额最高的一张券。</text>
  </view>
</view>
