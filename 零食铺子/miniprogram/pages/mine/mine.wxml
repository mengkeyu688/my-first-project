<view class="page mine-page">
  <view class="user-card card">
    <image class="avatar" src="{{user.avatar}}" mode="aspectFill"></image>
    <view class="user-info">
      <text class="nick">{{user.nickName}}</text>
      <text class="muted">校园宿舍零食会员</text>
    </view>
    <view class="points-box">
      <text>{{user.points}}</text>
      <text>积分</text>
    </view>
  </view>

  <view class="quick-grid card">
    <view class="quick-item" bindtap="goOrders">
      <text class="quick-num">{{orderCount}}</text>
      <text>我的订单</text>
    </view>
    <view class="quick-item" bindtap="goFavorite">
      <text class="quick-num">{{favoriteCount}}</text>
      <text>我的收藏</text>
    </view>
    <view class="quick-item" bindtap="goCoupon">
      <text class="quick-num">{{couponCount}}</text>
      <text>优惠券</text>
    </view>
    <view class="quick-item">
      <text class="quick-num">{{browseCount}}</text>
      <text>浏览记录</text>
    </view>
  </view>

  <view class="section">
    <view class="section-title">
      <text>积分兑换</text>
      <text class="muted">消费 1 元得 1 积分</text>
    </view>
    <view class="redeem-grid">
      <view wx:for="{{redeemList}}" wx:key="name" class="redeem-card card">
        <image src="{{item.image}}" mode="aspectFill"></image>
        <view>
          <text class="redeem-name">{{item.name}}</text>
          <text class="muted">{{item.cost}} 积分</text>
        </view>
        <button class="ghost-btn" data-name="{{item.name}}" data-cost="{{item.cost}}" bindtap="redeem">兑换</button>
      </view>
    </view>
  </view>

  <view class="menu-card card">
    <view wx:for="{{menus}}" wx:key="key" class="menu-row" data-key="{{item.key}}" bindtap="tapMenu">
      <text>{{item.name}}</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="section">
    <view class="section-title">
      <text>最近浏览</text>
      <text class="muted">猜你喜欢数据来源</text>
    </view>
    <scroll-view wx:if="{{browseProducts.length}}" class="browse-scroll" scroll-x enable-flex>
      <view wx:for="{{browseProducts}}" wx:key="id" class="browse-card card" data-id="{{item.id}}" bindtap="goDetail">
        <image src="{{item.image}}" mode="aspectFill"></image>
        <text>{{item.name}}</text>
      </view>
    </scroll-view>
    <view wx:else class="empty small-empty">暂无浏览记录</view>
  </view>
</view>
