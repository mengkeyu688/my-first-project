<view wx:if="{{product}}" class="detail-page">
  <swiper class="detail-swiper" autoplay circular indicator-dots indicator-color="rgba(255,255,255,.55)" indicator-active-color="#ffffff">
    <swiper-item wx:for="{{product.images}}" wx:key="*this">
      <image src="{{item}}" mode="aspectFill"></image>
    </swiper-item>
  </swiper>

  <view class="detail-main card">
    <view class="name-row">
      <text class="detail-name">{{product.name}}</text>
      <button class="favorite {{isFavorite ? 'active' : ''}}" bindtap="toggleFavorite">{{isFavorite ? '已收藏' : '收藏'}}</button>
    </view>
    <view class="price-row">
      <text class="price">¥{{product.price}}</text>
      <text class="origin">¥{{product.originPrice}}</text>
    </view>
    <view class="stat-row">
      <text>库存 {{product.stock}}</text>
      <text>月销 {{product.sales_count_text}}</text>
      <text wx:if="{{product.isNew}}" class="pill">新品</text>
    </view>
  </view>

  <view class="detail-section card">
    <view class="section-title">商品介绍</view>
    <text class="desc">{{product.desc}}</text>
  </view>

  <view class="detail-section card">
    <view class="section-title">规格参数</view>
    <view class="param-row">
      <text>分类</text>
      <text>{{product.category}}</text>
    </view>
    <view class="param-row">
      <text>规格</text>
      <text>{{product.spec}}</text>
    </view>
    <view class="param-row">
      <text>保质期</text>
      <text>{{product.shelfLife}}</text>
    </view>
    <view class="param-row">
      <text>配送范围</text>
      <text>校园宿舍区</text>
    </view>
  </view>

  <view class="buy-bar fixed-bottom">
    <button class="share-btn" open-type="share">分享</button>
    <button class="ghost-btn" bindtap="addCart">加入购物车</button>
    <button class="primary-btn" bindtap="buyNow">立即购买</button>
  </view>
</view>

<view wx:else class="empty">商品不存在或已下架</view>
