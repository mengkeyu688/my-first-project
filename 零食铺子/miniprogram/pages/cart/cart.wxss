.cart-page {
  padding-bottom: calc(150rpx + env(safe-area-inset-bottom));
}

.cart-card {
  position: relative;
  display: flex;
  align-items: center;
  min-height: 210rpx;
  margin-bottom: 18rpx;
  padding: 20rpx;
}

.select-circle {
  flex: none;
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #dddddd;
  border-radius: 50%;
  background: #ffffff;
}

.select-circle.checked {
  border-color: #ff6b01;
  background: #ff6b01;
  box-shadow: inset 0 0 0 9rpx #ffffff;
}

.cart-card image {
  flex: none;
  width: 160rpx;
  height: 160rpx;
  aspect-ratio: 1 / 1;
  margin-left: 18rpx;
  border-radius: 14rpx;
}

.cart-info {
  display: flex;
  flex: 1;
  min-width: 0;
  min-height: 160rpx;
  padding: 0 60rpx 0 18rpx;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  display: -webkit-box;
  overflow: hidden;
  color: #222222;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1.35;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.price {
  font-weight: 900;
}

.redeem-tag {
  align-self: flex-start;
  padding: 5rpx 12rpx;
  border-radius: 999px;
  color: #19a974;
  background: #e9fff3;
  font-size: 22rpx;
}

.cart-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.stepper {
  display: flex;
  align-items: center;
  overflow: hidden;
  height: 60rpx;
  border: 1rpx solid #ff6b01;
  border-radius: 999px;
  background: #ffffff;
}

.stepper button,
.stepper text {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 60rpx;
  height: 60rpx;
  color: #ffffff;
  background: #ff6b01;
  font-size: 26rpx;
  font-weight: 800;
}

.stepper text {
  min-width: 54rpx;
  color: #222222;
  background: #ffffff;
}

.delete {
  position: absolute;
  right: 20rpx;
  top: 20rpx;
  color: #999999;
  font-size: 24rpx;
}

.cost-card {
  margin-top: 24rpx;
  padding: 24rpx;
}

.cost-row {
  display: flex;
  justify-content: space-between;
  min-height: 58rpx;
  color: #555555;
  font-size: 27rpx;
}

.coupon-tip {
  margin-top: 12rpx;
  padding: 16rpx;
  border-radius: 12px;
  color: #ff6b01;
  background: #fff1e5;
  font-size: 24rpx;
}

.settle-bar {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.all-select {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #555555;
  font-size: 26rpx;
}

.settle-total {
  display: flex;
  align-items: baseline;
  flex: 1;
  justify-content: flex-end;
  gap: 8rpx;
  color: #666666;
}

.settle-btn {
  width: 220rpx;
  min-height: 86rpx;
}

.empty-btn {
  width: 240rpx;
  margin: 30rpx auto 0;
}
